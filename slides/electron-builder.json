{
  "appId": "tv.monstudio.mstvclick",
  "productName": "MSTV Click",
  "electronVersion": "27.3.11",
  "directories": {
    "output": "dist-slides"
  },
  "files": [
    "slides/main.cjs",
    "slides/preload.cjs",
    "slides/renderer.html",
    "package.json"
  ],
  "extraMetadata": {
    "main": "slides/main.cjs",
    "name": "mstv-click"
  },
  "mac": {
    "category": "public.app-category.productivity",
    "icon": "assets/icons/mstv-visio.icns",
    "target": "dir",
    "hardenedRuntime": true,
    "entitlements": "slides/entitlements.mac.plist",
    "entitlementsInherit": "slides/entitlements.mac.plist",
    "extendInfo": {
      "LSMinimumSystemVersion": "10.15.0",
      "NSAppleEventsUsageDescription": "MSTV Click envoie les touches flèche gauche/droite à l’application de présentation active."
    }
  }
}
